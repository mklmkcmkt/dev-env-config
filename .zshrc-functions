# --- Environment Health Check ---
_check_dev_paths() {
  local required_dirs=("$HOME/.kube" "$HOME/.ssh" "$HOME/.config/gcloud")
  for d in "${required_dirs[@]}"; do
    if [[ ! -d "$d" ]]; then
      mkdir -p "$d"
    fi
  done
}
_check_dev_paths

# --- Container Aliases ---
run-env() {
  if [[ -z "$1" ]]; then echo "Usage: run-env [app | infra | base]"; return 1; fi
  local env_name="$1"
  local image_name=""
  local project_mount=""
  local extra_args=()

  case "$env_name" in
    app)   
      image_name="localhost/dev-app:latest"
      project_mount="$HOME/app-projects:/projects" 
      ;;
    infra) 
      image_name="localhost/dev-infra:latest"
      project_mount="$HOME/infra-projects:/projects"
      extra_args+=("-v" "$HOME/.kube:/root/.kube") 
      ;;
    base)  
      image_name="localhost/dev-base:latest"
      project_mount="$HOME:/projects"
      extra_args+=("-v" "$HOME/.kube:/root/.kube") 
      ;;
    *) echo "Error: Unknown environment '$env_name'."; return 1 ;;
  esac

  /usr/bin/podman run -it --rm \
    -v "$HOME/dev-env-config/.zshrc:/root/.zshrc" \
    -v "$HOME/dev-env-config/.gitconfig:/root/.gitconfig" \
    -v "$HOME/dev-env-config/config.nu:/root/.config/nushell/config.nu" \
    -v "$HOME/.zsh_secrets:/root/.zsh_secrets:ro" \
    -v "$HOME/.config/gcloud:/root/.config/gcloud" \
    -v "$HOME/snap/gh/current/.config/gh:/root/.config/gh" \
    -v "$HOME/.ssh:/root/.ssh:ro" \
    -v "$project_mount" \
    "${extra_args[@]}" \
    -e "GEMINI_API_KEY" \
    --name "${env_name}-dev" \
    "$image_name"
}

# --- Aliases ---
alias apps="run-env app"
alias infra="run-env infra"
alias base="run-env base"

# --- Goose Host ---
goose-host() {
  /usr/bin/podman run -it --rm \
    -v ~/.config/goose:/root/.config/goose:U \
    -v ~/.gemini:/root/.gemini:U \
    -v ~/app-projects:/workspace/app-projects:U \
    -v ~/dev-env-config:/workspace/dev-env-config:U \
    -v ~/infra-projects:/workspace/infra-projects:U \
    -v ~/labs:/workspace/labs:U \
    -v ~/local-agent:/workspace/local-agent:U \
    -v ~/dev-env:/workspace/dev-env:U \
    -v ~/.cargo:/root/.cargo:U \
    -v ~/.dotnet:/root/.dotnet:U \
    -v ~/.rustup:/root/.rustup:U \
    -v ~/.terraform.d:/root/.terraform.d:U \
    -v ~/.vscode:/root/.vscode:U \
    -v ~/.gitconfig:/root/.gitconfig:ro,U \
    -v ~/.profile:/root/.profile:ro,U \
    -v ~/.zshenv:/root/.zshenv:ro,U \
    -v ~/.oh-my-zsh:/root/.oh-my-zsh:ro,U \
    goose-host
}
